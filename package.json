{
  "name": "nexgen-study",
  "version": "1.0.0",
  "description": "NexGen Study — AI Academic Companion by Corverxis Technologies",
  "main": "src/api/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node src/api/server.js",
    "dev": "nodemon src/api/server.js",
    "build": "npm run prisma:generate",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "node src/prisma/seed.js",
    "test": "jest --passWithNoTests",
    "lint": "eslint src/",
    "audit:security": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@prisma/client": "^5.14.0",
    "@supabase/supabase-js": "^2.43.4",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^9.0.3",
    "openid-client": "^5.6.5",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-microsoft": "^1.0.0",
    "pino": "^9.2.0",
    "pino-http": "^10.1.0",
    "speakeasy": "^2.0.0",
    "stripe": "^15.12.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "eslint": "^9.4.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.3",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/*.test.js"
    ]
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}