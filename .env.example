# ══════════════════════════════════════════════════════════════════
# NexGen Study — Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── APP ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
APP_URL=https://your-app.onrender.com
APP_NAME=NexGen Study
CORVERXIS_BRAND=Corverxis Technologies Ltd

# ── DATABASE (Render PostgreSQL or external) ─────────────────────
DATABASE_URL=postgresql://user:password@host:5432/nexgen_study?sslmode=require

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-256-bit-secret
JWT_REFRESH_EXPIRES_IN=30d

# ── SUPABASE (Auth + Realtime) ───────────────────────────────────
SUPABASE_URL=https://bvwgqafekmfqpylsrteu.supabase.co
SUPABASE_ANON_KEY=sb_publishable_giKFkcglGwHs2ezDp0UsKQ_tmZ3QJis
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── ANTHROPIC API ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=4096

# ── STRIPE ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SCHOLAR=price_scholar_id_here
STRIPE_PRICE_RESEARCHER=price_researcher_id_here
STRIPE_SCHOLAR_LINK=https://buy.stripe.com/14A9AT9p83rfbDddjI1oI0k
STRIPE_RESEARCHER_LINK=https://buy.stripe.com/dRm7sL7h09PDePpa7w1oI0l

# ── OAUTH2 ────────────────────────────────────────────────────────
# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-app.onrender.com/api/auth/google/callback

# Microsoft OAuth2
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_CALLBACK_URL=https://your-app.onrender.com/api/auth/microsoft/callback

# ── EMAIL (SMTP via Resend / SendGrid) ───────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=re_your_resend_api_key
EMAIL_FROM=NexGen Study <support@corverxis.com>

# ── SECURITY ─────────────────────────────────────────────────────
ENCRYPTION_KEY=your-32-byte-hex-encryption-key
SESSION_SECRET=your-session-secret-here
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
RATE_LIMIT_AI_MAX=20

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=https://your-app.onrender.com,https://corverxis.com

# ── LOGGING (SOC 2 audit trail) ──────────────────────────────────
LOG_LEVEL=info
AUDIT_LOG_RETENTION_DAYS=365

# ── DATA RETENTION (GDPR) ────────────────────────────────────────
DEFAULT_DATA_RETENTION_DAYS=365
TRIAL_EXPIRY_DAYS=7
FREE_DAILY_LIMIT=3
SCHOLAR_DAILY_LIMIT=999999
RESEARCHER_DAILY_LIMIT=999999
